#!/usr/bin/env sh
# Pre-commit chain (run in order, stops on first failure):
#   1. Full-repo eslint scan — HARD BLOCK on any error (complexity, unused, etc.)
#   2. lint-staged (eslint --fix + prettier --write on staged files)
#   3. coderabbit review (informational, non-blocking)
#
# Skip the AI review with: SKIP_CODERABBIT=1 git commit ...
# Skip the full-repo scan with: SKIP_FULL_LINT=1 git commit ...   (use sparingly — defeats the gate)
# Skip everything with:    git commit --no-verify ...

set -e

# 1) Full-repo eslint scan (blocking on any error)
if [ "${SKIP_FULL_LINT:-0}" = "1" ]; then
	echo "[pre-commit] SKIP_FULL_LINT=1 — skipping full-repo eslint scan"
else
	echo "[pre-commit] full-repo eslint scan (cognitive complexity ≤5, no unused, etc.)..."
	npx eslint . --config config/eslint.config.js
fi

# 2) Lint + format staged files (blocking)
npx lint-staged

# 3) CodeRabbit review (non-blocking, informational)
if [ "${SKIP_CODERABBIT:-0}" = "1" ]; then
	echo "[pre-commit] SKIP_CODERABBIT=1 — skipping coderabbit review"
	exit 0
fi

if ! command -v coderabbit >/dev/null 2>&1; then
	echo "[pre-commit] coderabbit CLI not installed — skipping review (install: curl -fsSL https://cli.coderabbit.ai/install.sh | sh)"
	exit 0
fi

if ! coderabbit auth status >/dev/null 2>&1; then
	echo "[pre-commit] coderabbit not authenticated — skipping review (run: coderabbit auth login)"
	exit 0
fi

echo "[pre-commit] running coderabbit review (set SKIP_CODERABBIT=1 to skip)..."
LOG=/tmp/coderabbit-pre-commit-$$.log
if coderabbit review --agent -t uncommitted >"$LOG" 2>&1; then
	CRITICAL=$(grep -c '"severity":"critical"' "$LOG" || true)
	MAJOR=$(grep -c '"severity":"major"' "$LOG" || true)
	MINOR=$(grep -c '"severity":"minor"' "$LOG" || true)
	INFO=$(grep -c '"severity":"info"' "$LOG" || true)
	echo "[pre-commit] coderabbit findings — critical:$CRITICAL major:$MAJOR minor:$MINOR info:$INFO (full log: $LOG)"
	if [ "$CRITICAL" -gt 0 ] || [ "$MAJOR" -gt 0 ]; then
		echo "[pre-commit] ⚠  Major/critical findings detected. Review $LOG before pushing."
		echo "[pre-commit]    (commit allowed; this hook is informational only)"
	fi
else
	echo "[pre-commit] coderabbit review failed — continuing (see $LOG)"
fi

exit 0
