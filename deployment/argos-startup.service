[Unit]
Description=Argos Startup Health Check
After=network-online.target earlyoom.service zram-swap.service
Wants=network-online.target

[Service]
Type=oneshot
User=__SETUP_USER__
Group=__SETUP_USER__
ExecStart=__PROJECT_DIR__/scripts/startup-check.sh
RemainAfterExit=yes
StandardOutput=journal
StandardError=journal
SyslogIdentifier=argos-startup

[Install]
WantedBy=multi-user.target
